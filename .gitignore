# Nuxt

# Logs
/metal_front/logs
/metal_front/*.log
/metal_front/npm-debug.log*
/metal_front/yarn-debug.log*
/metal_front/yarn-error.log*

# Runtime data
/metal_front/pids
/metal_front/*.pid
/metal_front/*.seed
/metal_front/*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
/metal_front/lib-cov

# Coverage directory used by tools like istanbul
/metal_front/coverage

# nyc test coverage
/metal_front/.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
/metal_front/.grunt

# Bower dependency directory (https://bower.io/)
/metal_front/bower_components

# node-waf configuration
/metal_front/.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
/metal_front/build/Release

# Dependency directories
/metal_front/node_modules/
metal_front/jspm_packages/

# TypeScript v1 declaration files
metal_front/typings/

# Optional npm cache directory
metal_front/.npm

# Optional eslint cache
metal_front/.eslintcache

# Optional REPL history
metal_front/.node_repl_history

# Output of 'npm pack'
metal_front/*.tgz

# Yarn Integrity file
metal_front/.yarn-integrity

# dotenv environment variables file
metal_front/.env

# parcel-bundler cache (https://parceljs.org/)
metal_front/.cache

# next.js build output
metal_front/.next

# nuxt.js build output
metal_front/.nuxt

# Nuxt generate
metal_front/dist

# vuepress build output
metal_front/.vuepress/dist

# Serverless directories
metal_front/.serverless

# IDE / Editor
metal_front/.idea

# Service worker
metal_front/sw.*

# macOS
metal_front/.DS_Store

# Vim swap files
metal_front/*.swp

# api

# Ignore bundler config.
api/.bundle

# Ignore all logfiles and tempfiles.
api/log/*
api/tmp/*
!api/log/.keep
!api/tmp/.keep

# Ignore pidfiles, but keep the directory.
api/tmp/pids/*
!api/tmp/pids/
!api/tmp/pids/.keep

# Ignore uploaded files in development.
api/storage/*
!api/storage/.keep
api/tmp/storage/*
!api/tmp/storage/
!api/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
api/config/master.key
