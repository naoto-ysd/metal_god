# Nuxt

# Logs
/front-metal/logs
/front-metal/*.log
/front-metal/npm-debug.log*
/front-metal/yarn-debug.log*
/front-metal/yarn-error.log*

# Runtime data
/front-metal/pids
/front-metal/*.pid
/front-metal/*.seed
/front-metal/*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
/front-metal/lib-cov

# Coverage directory used by tools like istanbul
/front-metal/coverage

# nyc test coverage
/front-metal/.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
/front-metal/.grunt

# Bower dependency directory (https://bower.io/)
/front-metal/bower_components

# node-waf configuration
/front-metal/.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
/front-metal/build/Release

# Dependency directories
/front-metal/node_modules/
front-metal/jspm_packages/

# TypeScript v1 declaration files
front-metal/typings/

# Optional npm cache directory
front-metal/.npm

# Optional eslint cache
front-metal/.eslintcache

# Optional REPL history
front-metal/.node_repl_history

# Output of 'npm pack'
front-metal/*.tgz

# Yarn Integrity file
front-metal/.yarn-integrity

# dotenv environment variables file
front-metal/.env

# parcel-bundler cache (https://parceljs.org/)
front-metal/.cache

# next.js build output
front-metal/.next

# nuxt.js build output
front-metal/.nuxt

# Nuxt generate
front-metal/dist

# vuepress build output
front-metal/.vuepress/dist

# Serverless directories
front-metal/.serverless

# IDE / Editor
front-metal/.idea

# Service worker
front-metal/sw.*

# macOS
front-metal/.DS_Store

# Vim swap files
front-metal/*.swp

# api

# Ignore bundler config.
api/.bundle

# Ignore all logfiles and tempfiles.
api/log/*
api/tmp/*
!api/log/.keep
!api/tmp/.keep

# Ignore pidfiles, but keep the directory.
api/tmp/pids/*
!api/tmp/pids/
!api/tmp/pids/.keep

# Ignore uploaded files in development.
api/storage/*
!api/storage/.keep
api/tmp/storage/*
!api/tmp/storage/
!api/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
api/config/master.key
